# Core Bot Configuration
BOT_TOKEN=7xxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_URL=https://yourdomain.com/webhook
WEBHOOK_SECRET=your_random_secret_here
PORT=8000
ENVIRONMENT=development

# Bot Owner/Administrators
SUDO_USERS=123456789,987654321

# ACN Leadership (Telegram User IDs)
CAPTAIN_ID=123456789
COMMANDER_IDS=234567890,345678901,456789012

# Group/Channel Restrictions (Telegram IDs)
# Bot will ONLY respond in these groups. Leave empty to allow all.
ALLOWED_GROUP_IDS=-1001234567890,-1009876543210
# Posts in these channels will be auto-purged. Leave empty for none.
PURGE_CHANNEL_IDS=-1001111111111,-1002222222222

# ── Security Configuration ──
# API key required to access /metrics and /websocket/stats endpoints
METRICS_API_KEY=your_random_api_key_here

# Rate Limiting (commands per minute)
RATE_LIMIT_USER=20
RATE_LIMIT_GROUP=60
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_COOLDOWN=30
RATE_LIMIT_BAN_THRESHOLD=5

# Database Pool Hardening
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_QUERY_TIMEOUT=10
DB_POOL_RECYCLE=1800
DB_SSL_REQUIRED=false

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://robin:password@localhost:5432/robin_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Optional: AI
LLM_PROVIDER=disabled
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODERATION_MODEL=gpt-4o-mini
AI_MODERATION_ENABLED=false
AI_SCORE_THRESHOLD=0.75

# Optional: Log Channel (global fallback — receives errors, alerts, join/leave logs)
LOG_CHANNEL_ID=-100xxxxxxxxxx

# Bot Personality
BOT_NAME=Nico Robin
DEFAULT_LOCALE=en
DEFAULT_PREFIX=/
